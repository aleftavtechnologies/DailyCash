# --- Core (always required) -----------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dailycash?schema=public"
# For serverless (Neon pooled connection), DIRECT_URL is Neon's separate
# *unpooled* connection string, used only for running migrations. On
# Docker/VPS with a normal Postgres, just set this the same as DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/dailycash?schema=public"
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="8h"
PORT=4000
CORS_ORIGIN="http://localhost:5173"

# --- File storage ------------------------------------------------------
# "local"        = disk storage under backend/uploads (Docker/VPS only —
#                  serverless has no persistent filesystem)
# "vercel-blob"   = Vercel's built-in storage — simplest if deploying to
#                   Vercel, no separate account needed (enable "Blob" in
#                   your Vercel project's Storage tab, it injects
#                   BLOB_READ_WRITE_TOKEN automatically)
# "s3"            = S3-compatible storage (AWS S3, Cloudflare R2,
#                   Backblaze B2) — for non-Vercel serverless deploys
STORAGE_DRIVER="local"
# Only used when STORAGE_DRIVER=s3:
S3_BUCKET=""
S3_REGION="auto"
S3_ENDPOINT=""            # e.g. https://<account-id>.r2.cloudflarestorage.com — leave blank for real AWS S3
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL_BASE=""     # e.g. https://pub-xxxx.r2.dev or your CDN domain fronting the bucket
# Only used when STORAGE_DRIVER=vercel-blob (auto-set by Vercel, no action needed):
BLOB_READ_WRITE_TOKEN=""
