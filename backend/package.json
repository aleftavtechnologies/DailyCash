{
  "name": "dailycash-backend",
  "version": "0.1.0",
  "private": true,
  "description": "DailyCash micro-credit operations backend — Express + Prisma + PostgreSQL + Socket.io",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "postinstall": "prisma generate",
