    "prisma:migrate": "prisma migrate dev --name init",
    "seed": "node src/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@vercel/blob": "^0.27.0",
    "@prisma/client": "^5.18.0",
    "prisma": "^5.18.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}