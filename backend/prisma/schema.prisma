// DailyCash — Micro-Credit Operations System
// Prisma schema implementing the data model described in
// DailyCash_System_Specification.docx §5

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Only needed for serverless deploys against a pooled connection
  // string (e.g. Neon) — migrations need a direct, unpooled connection.
  // On Docker/VPS with a normal Postgres, DIRECT_URL can just equal
  // DATABASE_URL (see backend/.env.example).
  directUrl = env("DIRECT_URL")
}

enum Role {
  admin
  accountant
  loan_officer
  recovery_officer
}

enum LoanStatus {
  pending
  approved
  rejected
  active
  overdue
  completed
  written_off
}

enum InterestType {
  flat_percent
  fixed_total
}

enum PaymentType {
  installment
  bank_transfer
  document_charge
  other_charge
  office_payment
}

enum CashMovementType {
  float_in       // admin issues starting/top-up cash float to an officer
  disbursement   // officer pays out a loan principal from their cash in hand
  deposit_out    // officer deposits cash to the company bank account (month-end)
  adjustment     // manual correction, admin only
}

model Tenant {
  id              String   @id @default(cuid())
  companyName     String
  status          String   @default("active")
  subscriptionPlan String  @default("standard")
  createdAt       DateTime @default(now())

  branches      Branch[]
  users         User[]
  customers     Customer[]
  loanProducts  LoanProduct[]
  loans         Loan[]
  payments      Payment[]
  comments      Comment[]
  cashMovements CashMovement[]
  auditLogs     AuditLog[]
}

model Branch {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  name     String
  address  String?

  // One branch = one collection route = exactly one loan officer.
  // Enforced here via a unique FK (a loan officer can be the route owner
  // of at most one branch) and re-checked in the API layer when assigning.
  loanOfficerId String? @unique
  loanOfficer   User?   @relation("BranchRouteOfficer", fields: [loanOfficerId], references: [id])

  users     User[]      @relation("BranchStaff")
  customers Customer[]
  loans     Loan[]
  payments  Payment[]
  cashMovements CashMovement[]

  @@index([tenantId])
}

model User {
  id           String  @id @default(cuid())
  tenantId     String
  tenant       Tenant  @relation(fields: [tenantId], references: [id])
  branchId     String?
  branch       Branch? @relation("BranchStaff", fields: [branchId], references: [id])
  name         String
  phone        String
  passwordHash String
  role         Role
  active       Boolean @default(true)
  createdAt    DateTime @default(now())

  routeBranch    Branch?    @relation("BranchRouteOfficer")
  loansAsOfficer Loan[]     @relation("LoanOfficer")
  loansSubmitted Loan[]     @relation("LoanSubmittedBy")
  loansApproved  Loan[]     @relation("LoanApprovedBy")
  paymentsRecorded Payment[] @relation("RecordedBy")
  documentsUploaded LoanDocument[] @relation("DocumentUploadedBy")
  cashMovements  CashMovement[] @relation("CashMovementOfficer")
  cashMovementsRecorded CashMovement[] @relation("CashMovementRecordedBy")
  comments       Comment[]
  recoveryLogs   RecoveryLog[]
  auditLogs      AuditLog[]

  @@index([tenantId, branchId])
}

model Customer {
  id           String  @id @default(cuid())
  tenantId     String
  tenant       Tenant  @relation(fields: [tenantId], references: [id])
  branchId     String
  branch       Branch  @relation(fields: [branchId], references: [id])
  name         String
  nic          String
  phone        String
  address      String?
  businessType String?
  photoUrl     String?
  createdAt    DateTime @default(now())

  guarantors Guarantor[]
  loans      Loan[]
  payments   Payment[]
  comments   Comment[]

  @@index([tenantId, branchId])
}

model Guarantor {
  id           String   @id @default(cuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  name         String
  nic          String
  phone        String
  relationship String?
}

model LoanProduct {
  id           String       @id @default(cuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  name         String
  termDays     Int
  interestType InterestType @default(flat_percent)
  interestValue Float       // percent if flat_percent, total repayable multiplier/amount if fixed_total
  lateFeeRule  Json?        // { type: "flat"|"percent", value: number }
  skipSundays  Boolean      @default(false)
  active       Boolean      @default(true)

  loans Loan[]
}

model Loan {
  id               String     @id @default(cuid())
  tenantId         String
  tenant           Tenant     @relation(fields: [tenantId], references: [id])
  branchId         String
  branch           Branch     @relation(fields: [branchId], references: [id])
  customerId       String
  customer         Customer   @relation(fields: [customerId], references: [id])
  productId        String
  product          LoanProduct @relation(fields: [productId], references: [id])
  officerId        String
  officer          User       @relation("LoanOfficer", fields: [officerId], references: [id])
  principal        Float
  termDays         Int
  interestValue    Float
  totalRepayable   Float
  installmentAmount Float
  startDate        DateTime
  status           LoanStatus @default(pending)
  createdAt        DateTime   @default(now())

  // Approval workflow: loan officer submits -> admin approves/rejects ->
  // (if approved) loan officer disburses cash from their own float.
  submittedById    String?
  submittedBy      User?      @relation("LoanSubmittedBy", fields: [submittedById], references: [id])
  approvedById     String?
  approvedBy       User?      @relation("LoanApprovedBy", fields: [approvedById], references: [id])
  approvedAt       DateTime?
  rejectedReason   String?
  disbursedAt      DateTime?

  schedule     InstallmentSchedule[]
  payments     Payment[]
  recoveryLogs RecoveryLog[]
  documents    LoanDocument[]
  cashMovements CashMovement[]

  @@index([tenantId, branchId, status])
}

// Uploaded at application time: NIC photos, business photo, signature,
// guarantor ID, etc. Stored on local disk in dev (see src/lib/upload.js);
// swap the STORAGE_DRIVER env var to "s3" in production.
model LoanDocument {
  id           String   @id @default(cuid())
  loanId       String
  loan         Loan     @relation(fields: [loanId], references: [id])
  type         String   // nic_photo | business_photo | signature | guarantor_nic | other
  fileUrl      String
  originalName String?
  uploadedById String
  uploadedBy   User     @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([loanId])
}

model InstallmentSchedule {
  id          String   @id @default(cuid())
  loanId      String
  loan        Loan     @relation(fields: [loanId], references: [id])
  sequenceNo  Int
  dueDate     DateTime
  amountDue   Float
  status      String   @default("pending") // pending | paid | missed

  @@index([loanId, dueDate])
}

// Unified ledger — every money movement in the system is one row here.
// type determines which roles may create it (enforced in the API layer,
// see src/routes/payments.js and the spec §6/§7).
model Payment {
  id         String      @id @default(cuid())
  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  branchId   String
  branch     Branch      @relation(fields: [branchId], references: [id])
  loanId     String?
  loan       Loan?       @relation(fields: [loanId], references: [id])
  customerId String?
  customer   Customer?   @relation(fields: [customerId], references: [id])
  type       PaymentType
  amount     Float
  note       String?
  recordedById String
  recordedBy   User      @relation("RecordedBy", fields: [recordedById], references: [id])
  gpsLat     Float?
  gpsLng     Float?
  syncStatus String      @default("synced") // synced | pending (offline queue)
  createdAt  DateTime    @default(now())

  @@index([tenantId, branchId, createdAt])
  @@index([loanId])
  @@index([customerId])
}

// Any role can write; visible to all roles who can see the customer.
model Comment {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  text       String
  createdAt  DateTime @default(now())

  @@index([customerId, createdAt])
}

model RecoveryLog {
  id              String   @id @default(cuid())
  loanId          String
  loan            Loan     @relation(fields: [loanId], references: [id])
  officerId       String
  officer         User     @relation(fields: [officerId], references: [id])
  visitDate       DateTime @default(now())
  notes           String?
  promiseToPayDate DateTime?

  @@index([loanId])
}

// Officer cash-float ledger. One branch = one route = one loan officer,
// and that officer disburses new loans out of cash they are physically
// holding (built up from daily collections — see Payment — plus any
// float top-up from admin), then deposits the surplus to the company
// bank account at month end. Balance = SUM(collections in) + SUM(float_in)
// - SUM(disbursement) - SUM(deposit_out), computed in src/routes/cash.js.
model CashMovement {
  id           String            @id @default(cuid())
  tenantId     String
  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  branchId     String
  branch       Branch            @relation(fields: [branchId], references: [id])
  officerId    String
  officer      User              @relation("CashMovementOfficer", fields: [officerId], references: [id])
  type         CashMovementType
  amount       Float
  loanId       String?
  loan         Loan?             @relation(fields: [loanId], references: [id])
  note         String?
  recordedById String
  recordedBy   User              @relation("CashMovementRecordedBy", fields: [recordedById], references: [id])
  createdAt    DateTime          @default(now())

  @@index([tenantId, branchId, officerId, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  @@index([tenantId, entity, entityId])
}
