VITE_API_URL=http://localhost:4000
# "socket" (default) = Docker/VPS backend with Socket.io, instant updates.
# "poll" = serverless backend (Vercel) — no persistent connection to push
# through, so this refetches every few seconds instead. Match whichever
# backend you're pointing VITE_API_URL at.
VITE_REALTIME_MODE=socket
